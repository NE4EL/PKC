<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:LibraryManagement.Models"
        x:Class="LibraryManagement.Views.GenreManagementWindow"
        Title="Управление жанрами" Width="600" Height="400">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionChanged="GenresDataGrid_SelectionChanged"
                  x:CompileBindings="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <Button Content="Добавить" Click="Add_Click" Width="120"/>
            <Button Content="Редактировать" Click="Edit_Click" Width="120"/>
            <Button Content="Удалить" Click="Delete_Click" Width="120"/>
            <Button Content="Закрыть" Click="Close_Click" Width="120"/>
        </StackPanel>
    </Grid>
</Window>