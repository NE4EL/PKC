<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:LibraryManagement.Models"
        x:Class="LibraryManagement.Views.AuthorManagementWindow"
        Title="Управление авторами" Width="700" Height="500">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionChanged="AuthorsDataGrid_SelectionChanged"
                  x:CompileBindings="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat='dd.MM.yyyy'}" Width="150"/>
                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
            <Button Content="Добавить" Click="Add_Click" Width="120"/>
            <Button Content="Редактировать" Click="Edit_Click" Width="120"/>
            <Button Content="Удалить" Click="Delete_Click" Width="120"/>
            <Button Content="Закрыть" Click="Close_Click" Width="120" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</Window>